{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_REVENUECAT_IOS_KEY": "REPLACE_WITH_YOUR_REVENUECAT_IOS_PUBLIC_KEY"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
